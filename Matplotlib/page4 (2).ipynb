    "plt.subplot(1,2,1)#1 row, 2nd column, 1st subplot\n",
    "plt.title(\"Line chart\")\n",
    "plt.plot(x,y)\n",
    "plt.subplot(1,2,2)#1st row, 2nd column, 2nd subplot\n",
    "plt.title(\"Bar chart\")\n",
    "plt.bar(x,y)"
   ]
